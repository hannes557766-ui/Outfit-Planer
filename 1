<script>
// ─── STATE ───────────────────────────────────────────
let apiKey = localStorage.getItem('gemini_api_key') || '';
let currentFilter = 'Alle';
let currentSlot = null;

const slotCategoryMap = {
  head: ['Accessoires'],
  outer: ['Jacken'],
  top: ['Tops', 'Kleider'],
  bottom: ['Hosen', 'Kleider'],
  shoes: ['Schuhe'],
  acc: ['Accessoires']
};

const slotLabels = {
  head: 'Kopfbedeckung',
  outer: 'Jacke / Outer',
  top: 'Top / Shirt',
  bottom: 'Hose / Rock',
  shoes: 'Schuhe',
  acc: 'Accessoire'
};

let currentOutfitSlots = { head: null, outer: null, top: null, bottom: null, shoes: null, acc: null };

let wardrobe = JSON.parse(localStorage.getItem('wardrobe') || '[]');
let outfits = JSON.parse(localStorage.getItem('outfits') || '[]');

// Seed data
if (wardrobe.length === 0) {
  wardrobe = [
    { id: 1, name: 'Weißes T-Shirt', emoji: '👕', category: 'Tops', brand: 'Uniqlo', color: '#FFFFFF' },
    { id: 2, name: 'Blaues Oxford Hemd', emoji: '👔', category: 'Tops', brand: 'COS', color: '#4A6FA5' },
    { id: 3, name: 'Schwarze Jeans', emoji: '👖', category: 'Hosen', brand: 'Levi\'s', color: '#1A1A2E' },
    { id: 4, name: 'Beige Chino', emoji: '🩳', category: 'Hosen', brand: 'Zara', color: '#D4B896' },
    { id: 5, name: 'White Sneakers', emoji: '👟', category: 'Schuhe', brand: 'Nike', color: '#FFFFFF' },
    { id: 6, name: 'Chelsea Boots', emoji: '🥾', category: 'Schuhe', brand: 'Dr. Martens', color: '#2C1810' },
    { id: 7, name: 'Denim Jacket', emoji: '🧥', category: 'Jacken', brand: 'Weekday', color: '#4A6FA5' },
    { id: 8, name: 'Silberne Uhr', emoji: '⌚', category: 'Accessoires', brand: 'Casio', color: '#C0C0C0' },
    { id: 9, name: 'Strick-Pullover', emoji: '🧶', category: 'Tops', brand: 'H&M', color: '#8B7355' },
    { id: 10, name: 'Leather Belt', emoji: '🪢', category: 'Accessoires', brand: 'Zara', color: '#2C1810' },
  ];
  saveWardrobe();
}

const EMOJIS = ['👕','👔','🧥','🥼','👗','👘','🩱','🩲','🩳','👖','👗','👙','🧤','🧣','🎩','⛑️','👟','👠','👡','👢','🥾','🥿','🩴','👒','🕶️','💍','⌚','👜','👛','🎒','🧢','🩰','🪢','🧶','🪭'];
const COLORS = ['#FFFFFF','#1A1916','#4A6FA5','#D4B896','#8B7355','#C0C0C0','#2C1810','#5C8A5C','#E07070','#7B6B9E','#F5E6C8','#2D3748'];

// ─── INIT ────────────────────────────────────────────
function init() {
  updateBadge();
  renderEmojiGrid();
  renderColorSwatches();
  renderFilterRow();
  renderAll();
}

function saveWardrobe() { localStorage.setItem('wardrobe', JSON.stringify(wardrobe)); }
function saveOutfits() { localStorage.setItem('outfits', JSON.stringify(outfits)); }

// ─── NAV ─────────────────────────────────────────────
function showPage(name) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.getElementById('page-' + name).classList.add('active');
  document.querySelectorAll('.nav-btn').forEach(b => b.classList.remove('active'));
  const navMap = { today: 'nav-today', wardrobe: 'nav-wardrobe', builder: 'nav-builder', outfits: 'nav-outfits', stats: 'nav-stats' };
  if (navMap[name]) document.getElementById(navMap[name]).classList.add('active');
  if (name === 'wardrobe') renderWardrobe();
  if (name === 'outfits') renderOutfits();
  if (name === 'today') renderRecent();
  if (name === 'stats') renderStats();
}

function activateNav(id) {
  document.querySelectorAll('.nav-btn').forEach(b => b.classList.remove('active'));
  document.getElementById(id).classList.add('active');
}

// ─── RENDER ──────────────────────────────────────────
function renderAll() {
  renderWardrobe();
  renderOutfits();
  renderRecent();
  updateCounts();
}

function renderWardrobe() {
  const grid = document.getElementById('wardrobeGrid');
  const filtered = currentFilter === 'Alle' ? wardrobe : wardrobe.filter(i => i.category === currentFilter);
  document.getElementById('wardrobeSubtitle').textContent =
    currentFilter === 'Alle' ? `${wardrobe.length} Teile insgesamt` : `${filtered.length} ${currentFilter}`;

  if (filtered.length === 0) {
    grid.innerHTML = `<div class="empty-state" style="grid-column:1/-1">
      <div class="empty-icon">🧺</div>
      <div class="empty-title">Noch leer hier</div>
      <div class="empty-text">Füge deine ersten Kleidungsstücke hinzu.</div>
    </div>`;
    return;
  }

  grid.innerHTML = filtered.map(item => `
    <div class="clothing-card">
      <div class="clothing-image" style="background:${item.color}22">${item.emoji}</div>
      <div class="clothing-info">
        <div class="clothing-name">${item.name}</div>
        <div class="clothing-meta">
          <span class="clothing-tag">${item.category}</span>
          ${item.brand ? `<span style="color:var(--text-muted)">${item.brand}</span>` : ''}
        </div>
      </div>
    </div>
  `).join('');

  // Add button
  const addBtn = document.createElement('div');
  addBtn.className = 'add-card';
  addBtn.onclick = openAddModal;
  addBtn.innerHTML = '<div class="plus">+</div><div>Hinzufügen</div>';
  grid.appendChild(addBtn);
}

function renderOutfits() {
  const grid = document.getElementById('outfitsGrid');
  if (outfits.length === 0) {
    grid.innerHTML = `<div class="empty-state" style="grid-column:1/-1">
      <div class="empty-icon">✨</div>
      <div class="empty-title">Noch keine Outfits</div>
      <div class="empty-text">Erstelle dein erstes Outfit im Builder.</div>
    </div>`;
    return;
  }
  grid.innerHTML = outfits.map(o => renderOutfitCard(o)).join('');
}

function renderRecent() {
  const el = document.getElementById('recentOutfits');
  const recent = [...outfits].reverse().slice(0, 4);
  if (recent.length === 0) {
    el.innerHTML = `<div class="empty-state" style="grid-column:1/-1">
      <div class="empty-icon">👗</div>
      <div class="empty-title">Noch keine Outfits</div>
      <div class="empty-text">Erstelle dein erstes Outfit und es erscheint hier.</div>
    </div>`;
    return;
  }
  el.innerHTML = recent.map(o => renderOutfitCard(o)).join('');
}

function renderOutfitCard(o) {
  const items = Object.values(o.slots).filter(Boolean);
  const preview = items.slice(0, 4).map(id => {
    const item = wardrobe.find(w => w.id === id);
    return `<div class="outfit-preview-item">${item ? item.emoji : '?'}</div>`;
  }).join('');
  const tags = [o.occasion, o.season].filter(Boolean);
  return `<div class="outfit-card">
    <div class="outfit-preview">${preview}</div>
    <div class="outfit-info">
      <div class="outfit-name">${o.name}</div>
      <div class="outfit-tags">${tags.map(t => `<span class="outfit-tag">${t}</span>`).join('')}</div>
    </div>
  </div>`;
}

function renderStats() {
  const byCategory = {};
  wardrobe.forEach(i => { byCategory[i.category] = (byCategory[i.category] || 0) + 1; });
  const bars = Object.entries(byCategory).map(([cat, count]) => {
    const pct = Math.round((count / wardrobe.length) * 100);
    return `<div style="margin-bottom:12px;">
      <div style="display:flex;justify-content:space-between;font-size:13px;margin-bottom:4px;">
        <span>${cat}</span><span style="color:var(--text-muted)">${count} Stück</span>
      </div>
      <div style="height:6px;background:var(--surface2);border-radius:3px;overflow:hidden;">
        <div style="height:100%;width:${pct}%;background:var(--accent-warm);border-radius:3px;transition:width 0.6s ease;"></div>
      </div>
    </div>`;
  }).join('');

  document.getElementById('statsContent').innerHTML = `
    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-bottom:28px;">
      <div style="background:var(--surface);border:1.5px solid var(--border);border-radius:var(--radius);padding:20px;">
        <div style="font-size:32px;font-weight:500;">${wardrobe.length}</div>
        <div style="font-size:13px;color:var(--text-muted);margin-top:2px;">Kleidungsstücke</div>
      </div>
      <div style="background:var(--surface);border:1.5px solid var(--border);border-radius:var(--radius);padding:20px;">
        <div style="font-size:32px;font-weight:500;">${outfits.length}</div>
        <div style="font-size:13px;color:var(--text-muted);margin-top:2px;">Outfits gespeichert</div>
      </div>
      <div style="background:var(--surface);border:1.5px solid var(--border);border-radius:var(--radius);padding:20px;">
        <div style="font-size:32px;font-weight:500;">${Object.keys(byCategory).length}</div>
        <div style="font-size:13px;color:var(--text-muted);margin-top:2px;">Kategorien</div>
      </div>
    </div>
    <div style="background:var(--surface);border:1.5px solid var(--border);border-radius:var(--radius);padding:24px;">
      <div style="font-size:15px;font-weight:500;margin-bottom:20px;">Verteilung</div>
      ${bars}
    </div>`;
}

function updateCounts() {
  document.getElementById('wardrobeCountBadge').textContent = wardrobe.length;
  document.getElementById('outfitCountBadge').textContent = outfits.length;
}

// ─── FILTERS ─────────────────────────────────────────
const filters = ['Alle', 'Tops', 'Hosen', 'Schuhe', 'Jacken', 'Accessoires', 'Kleider'];

function renderFilterRow() {
  const row = document.getElementById('filterRow');
  row.innerHTML = filters.map(f => `
    <button class="filter-btn ${f === currentFilter ? 'active' : ''}" onclick="setFilter('${f}')">${f}</button>
  `).join('');
}

function setFilter(f) {
  currentFilter = f;
  showPage('wardrobe');
  renderFilterRow();
  renderWardrobe();
}

// ─── ADD MODAL ───────────────────────────────────────
let selectedEmoji = '👕';
let selectedColor = '#FFFFFF';

function renderEmojiGrid() {
  document.getElementById('emojiGrid').innerHTML = EMOJIS.map(e => `
    <div class="emoji-option ${e === selectedEmoji ? 'selected' : ''}" onclick="selectEmoji('${e}')">${e}</div>
  `).join('');
}

function renderColorSwatches() {
  document.getElementById('colorSwatches').innerHTML = COLORS.map(c => `
    <div class="color-swatch ${c === selectedColor ? 'selected' : ''}"
      style="background:${c};border:1.5px solid ${c === '#FFFFFF' ? '#ddd' : c}"
      onclick="selectColor('${c}')"></div>
  `).join('');
}

function selectEmoji(e) {
  selectedEmoji = e;
  renderEmojiGrid();
}

function selectColor(c) {
  selectedColor = c;
  renderColorSwatches();
}

function openAddModal() { document.getElementById('addModal').classList.add('open'); }
function closeAddModal() { document.getElementById('addModal').classList.remove('open'); }

function addItem() {
  const name = document.getElementById('itemName').value.trim();
  if (!name) { document.getElementById('itemName').focus(); return; }
  const item = {
    id: Date.now(),
    name,
    emoji: selectedEmoji,
    category: document.getElementById('itemCategory').value,
    brand: document.getElementById('itemBrand').value.trim(),
    color: selectedColor
  };
  wardrobe.push(item);
  saveWardrobe();
  updateCounts();
  closeAddModal();
  document.getElementById('itemName').value = '';
  document.getElementById('itemBrand').value = '';
  renderWardrobe();
}

// ─── SLOT PICKER ─────────────────────────────────────
function openSlotPicker(slot) {
  currentSlot = slot;
  document.getElementById('slotModalTitle').textContent = slotLabels[slot] + ' wählen';
  const cats = slotCategoryMap[slot];
  const items = wardrobe.filter(i => cats.includes(i.category));
  const grid = document.getElementById('slotPickerGrid');
  if (items.length === 0) {
    grid.innerHTML = `<div class="empty-state" style="grid-column:1/-1">
      <div class="empty-icon">🧺</div>
      <div class="empty-title">Keine Pieces</div>
      <div class="empty-text">Füge zuerst Kleidungsstücke in dieser Kategorie hinzu.</div>
    </div>`;
  } else {
    grid.innerHTML = items.map(item => `
      <div class="clothing-card ${currentOutfitSlots[slot] === item.id ? 'selected' : ''}" onclick="selectSlotItem(${item.id})">
        <div class="check">✓</div>
        <div class="clothing-image" style="background:${item.color}22">${item.emoji}</div>
        <div class="clothing-info">
          <div class="clothing-name">${item.name}</div>
          <div class="clothing-meta"><span class="clothing-tag">${item.category}</span></div>
        </div>
      </div>
    `).join('');
  }
  document.getElementById('slotModal').classList.add('open');
}

function closeSlotModal() { document.getElementById('slotModal').classList.remove('open'); }

function selectSlotItem(id) {
  currentOutfitSlots[currentSlot] = id;
  const item = wardrobe.find(i => i.id === id);
  const slot = document.getElementById('slot-' + currentSlot);
  slot.classList.add('filled');
  slot.querySelector('.slot-emoji').textContent = item.emoji;
  slot.querySelector('.slot-name').textContent = item.name;
  slot.querySelector('.slot-name').style.color = 'var(--text)';
  closeSlotModal();
}

function clearSlot(e, slot) {
  e.stopPropagation();
  currentOutfitSlots[slot] = null;
  const slotEl = document.getElementById('slot-' + slot);
  slotEl.classList.remove('filled');
  const defaults = { head:'🎩',outer:'🧥',top:'👕',bottom:'👖',shoes:'👟',acc:'💍' };
  slotEl.querySelector('.slot-emoji').textContent = defaults[slot];
  slotEl.querySelector('.slot-name').textContent = 'Tap zum Auswählen';
  slotEl.querySelector('.slot-name').style.color = 'var(--text-muted)';
}

// ─── SAVE OUTFIT ─────────────────────────────────────
function saveOutfit() {
  const name = document.getElementById('outfitName').value.trim() || 'Mein Outfit';
  const hasItems = Object.values(currentOutfitSlots).some(Boolean);
  if (!hasItems) { alert('Wähle mindestens ein Kleidungsstück aus.'); return; }
  const outfit = {
    id: Date.now(),
    name,
    occasion: document.getElementById('outfitOccasion').value,
    season: document.getElementById('outfitSeason').value,
    slots: { ...currentOutfitSlots },
    createdAt: new Date().toISOString()
  };
  outfits.push(outfit);
  saveOutfits();
  updateCounts();
  // Reset
  currentOutfitSlots = { head: null, outer: null, top: null, bottom: null, shoes: null, acc: null };
  document.getElementById('outfitName').value = '';
  ['head','outer','top','bottom','shoes','acc'].forEach(s => clearSlot({stopPropagation:()=>{}}, s));
  document.getElementById('builderAiResponse').classList.remove('visible');
  showPage('outfits');
}

// ─── API MODAL ───────────────────────────────────────
function openApiModal() { document.getElementById('apiModal').classList.add('open'); document.getElementById('apiKeyInput').value = apiKey; }
function closeApiModal() { document.getElementById('apiModal').classList.remove('open'); }

function saveApiKey() {
  const key = document.getElementById('apiKeyInput').value.trim();
  if (!key) return;
  apiKey = key;
  localStorage.setItem('gemini_api_key', key);
  updateBadge();
  closeApiModal();
}

function updateBadge() {
  const badge = document.getElementById('apiBadge');
  if (apiKey) {
    badge.textContent = '✓ Gemini verbunden';
    badge.classList.add('connected');
  } else {
    badge.textContent = '⚙ Gemini API';
    badge.classList.remove('connected');
  }
}

// ─── GEMINI API ──────────────────────────────────────
async function callGemini(prompt) {
  if (!apiKey) {
    openApiModal();
    return null;
  }

  const wardrobeContext = wardrobe.length > 0
    ? `Der Nutzer hat folgende Kleidungsstücke: ${wardrobe.map(i => `${i.emoji} ${i.name} (${i.category}${i.brand ? ', ' + i.brand : ''})`).join(', ')}.`
    : '';

  const systemPrompt = `Du bist ein stilsicherer Modeberater namens "fits. Assistant". 
Du gibst kurze, präzise und persönliche Styling-Ratschläge auf Deutsch.
Antworte in 2-4 Sätzen, sei konkret und inspirierend. Kein Markdown.
${wardrobeContext}`;

  try {
    const response = await fetch(
      `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.0-flash-exp:generateContent?key=${apiKey}`,
      {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          contents: [
            { role: 'user', parts: [{ text: systemPrompt + '\n\n' + prompt }] }
          ],
          generationConfig: { temperature: 0.8, maxOutputTokens: 300 }
        })
      }
    );
    const data = await response.json();
    if (data.error) { alert('API Fehler: ' + data.error.message); return null; }
    return data.candidates?.[0]?.content?.parts?.[0]?.text || 'Keine Antwort erhalten.';
  } catch (e) {
    alert('Verbindungsfehler: ' + e.message);
    return null;
  }
}

async function sendPrompt(customPrompt) {
  const input = document.getElementById('aiInput');
  const prompt = customPrompt || input.value.trim();
  if (!prompt) return;
  input.value = customPrompt || input.value;

  const responseEl = document.getElementById('aiResponse');
  const textEl = document.getElementById('aiResponseText');
  responseEl.classList.add('visible');
  textEl.innerHTML = `<div class="ai-loading">Gemini denkt nach <div class="dots"><span></span><span></span><span></span></div></div>`;

  const result = await callGemini(prompt);
  if (result) {
    textEl.textContent = result;
    if (!customPrompt) input.value = '';
  } else {
    responseEl.classList.remove('visible');
  }
}

async function askWeatherOutfit() {
  showPage('today');
  await sendPrompt('Es ist heute 18°C und leicht bewölkt in Frankfurt. Welches Outfit empfiehlst du für dieses Wetter?');
}

async function analyzeCurrentOutfit() {
  const items = Object.entries(currentOutfitSlots)
    .filter(([, id]) => id)
    .map(([slot, id]) => {
      const item = wardrobe.find(i => i.id === id);
      return item ? `${slotLabels[slot]}: ${item.emoji} ${item.name}` : null;
    }).filter(Boolean);

  if (items.length === 0) {
    alert('Wähle zuerst Kleidungsstücke aus.');
    return;
  }

  const respEl = document.getElementById('builderAiResponse');
  const textEl = document.getElementById('builderAiResponseText');
  respEl.classList.add('visible');
  textEl.innerHTML = `<div class="ai-loading">Analysiere dein Outfit <div class="dots"><span></span><span></span><span></span></div></div>`;

  const prompt = `Bewerte dieses Outfit: ${items.join(', ')}. Gib Feedback zur Kombination und einen Verbesserungsvorschlag.`;
  const result = await callGemini(prompt);
  if (result) textEl.textContent = result;
}

// ─── INIT ─────────────────────────────────────────────
init();
